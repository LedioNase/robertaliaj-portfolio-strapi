{
  "kind": "collectionType",
  "collectionName": "artworks",
  "info": {
    "singularName": "artwork",
    "pluralName": "artworks",
    "displayName": "Artwork"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "previewImage": {
      "type": "component",
      "component": "portfolio.preview-image",
      "repeatable": false
    },
    "mainMedia": {
      "type": "dynamiczone",
      "components": [
        "portfolio.video-media",
        "portfolio.image-media",
        "portfolio.external-video"
      ],
      "max": 1
    },
    "otherMedia": {
      "type": "dynamiczone",
      "components": [
        "portfolio.video-media",
        "portfolio.image-media",
        "portfolio.external-video"
      ]
    }
  }
}
